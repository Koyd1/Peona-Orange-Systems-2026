# ── Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/hrbot?sslmode=require
DATABASE_URL_ASYNC=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/hrbot?ssl=require

# ── MinIO 
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=hrbot-documents
MINIO_USE_SSL=false

# ── Redis 
REDIS_PASSWORD=CHANGE_ME

# ── OpenAI 
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o-mini
RAG_TOP_K=5
RAG_SIM_THRESHOLD=0.2
HEALTH_OPENAI_WARN_MS=1800
HEALTH_HALL_WARN_THRESHOLD=0.45

# ── NextAuth 
NEXTAUTH_SECRET=CHANGE_ME_at_least_32_chars
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@hr.local
ADMIN_PASSWORD=Admin123456!

# ── Internal (docker network)
PYTHON_BACKEND_URL=http://backend:8000
WEB_ORIGIN=http://frontend:3000

# ── Ingest pipeline
INGEST_TMP_DIR=/tmp/rag
INGEST_MAX_FILE_SIZE_MB=15

# ── Prod (optional)
APP_DOMAIN=localhost

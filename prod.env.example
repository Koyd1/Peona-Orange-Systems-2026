# Production env template
# Copy to .env on target host and replace all placeholder values.

# Database
DATABASE_URL=postgresql://user:pass@ep-prod.neon.tech/hrbot?sslmode=require
DATABASE_URL_ASYNC=postgresql+asyncpg://user:pass@ep-prod.neon.tech/hrbot?ssl=require

# MinIO
MINIO_ROOT_USER=prod-minio-user
MINIO_ROOT_PASSWORD=REPLACE_STRONG_PASSWORD
MINIO_BUCKET=hrbot-documents
MINIO_USE_SSL=false

# Redis
REDIS_PASSWORD=REPLACE_STRONG_PASSWORD

# OpenAI
OPENAI_API_KEY=sk-proj-REPLACE
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o-mini
RAG_TOP_K=5
RAG_SIM_THRESHOLD=0.2
HEALTH_OPENAI_WARN_MS=1800
HEALTH_HALL_WARN_THRESHOLD=0.45

# NextAuth
NEXTAUTH_SECRET=REPLACE_WITH_32_PLUS_CHARS
NEXTAUTH_URL=https://example.com
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=REPLACE_STRONG_PASSWORD

# Internal docker network
PYTHON_BACKEND_URL=http://backend:8000
WEB_ORIGIN=https://example.com

# Ingest
INGEST_TMP_DIR=/tmp/rag
INGEST_MAX_FILE_SIZE_MB=15

# App
APP_DOMAIN=example.com
